# ----------------------------------------------------------------------------
# Copy to .env and fill in the blanks. `make dev` reads this file.
# ----------------------------------------------------------------------------

# --- Host ports for docker compose ---
# Change these (and the ports in DATABASE_URL/QDRANT_URL below) if 5432/6333/6379
# are already in use by other containers on your machine.
POSTGRES_PORT="5432"
QDRANT_PORT="6333"
QDRANT_GRPC_PORT="6334"
REDIS_PORT="6379"

# --- Database (Postgres + pgvector) ---
DATABASE_URL="postgresql://pg:pg@localhost:5432/pgessays?schema=public"

# --- Qdrant (vector store) ---
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION="pg_essays"

# --- Redis (cache) ---
REDIS_URL="redis://localhost:6379"

# --- Google Gemini ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
EMBEDDING_MODEL="gemini-embedding-001"
EMBEDDING_DIM="768"
GENERATION_MODEL="gemini-2.5-flash"

# --- Ingestion ---
PG_RSS_URL="http://www.aaronsw.com/2002/feeds/pgessays.rss"
CHUNK_TOKENS="800"
CHUNK_OVERLAP="120"
# INGEST_LIMIT caps how many essays are ingested per run (handy for a quick test).
# Leave unset to ingest all.
# INGEST_LIMIT="12"

# --- Retrieval / generation ---
RETRIEVE_TOP_K="8"
RERANK_TOP_N="4"
SEMANTIC_CACHE_THRESHOLD="0.95"

# --- API ---
API_PORT="3001"
NODE_ENV="development"

# --- Web (Vite) ---
VITE_API_URL="http://localhost:3001"
