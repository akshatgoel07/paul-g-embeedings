model Essays {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  content     String
  link        String       @unique
  Hyperlinks  Hyperlinks[]
}

model Hyperlinks {
  id      Int    @id @default(autoincrement())
  essayId Int
  essays  Essays @relation(fields: [essayId], references: [id])
}
